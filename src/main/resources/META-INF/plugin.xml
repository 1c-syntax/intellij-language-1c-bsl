<idea-plugin>
  <id>io.github.1c-syntax.language-1c-bsl</id>
  <name>Language 1C (BSL)</name>
  <vendor email="nixel2007@gmail.com" url="https://github.com/1c-syntax">1c-syntax GitHub.com organization</vendor>

  <description><![CDATA[
      Support for the 1C:Enterprise (BSL) and OneScript languages in IntelliJ Platform-based IDEs.

      <ul>
        <li>Code intelligence — diagnostics, code completion, hover, go to definition, find usages,
            formatting, folding and structure view — provided by the
            <a href="https://github.com/1c-syntax/bsl-language-server">BSL Language Server</a>
            through <a href="https://github.com/redhat-developer/lsp4ij">LSP4IJ</a>.</li>
        <li>Syntax highlighting via a bundled TextMate grammar for BSL and its query language (SDBL).</li>
        <li>The language server is downloaded automatically on first use; an external
            <code>bsl-language-server.jar</code> can be configured instead.</li>
      </ul>

      Source code and issue tracker:
      <a href="https://github.com/1c-syntax/intellij-language-1c-bsl">github.com/1c-syntax/intellij-language-1c-bsl</a>.
    ]]></description>

  <depends>com.intellij.modules.platform</depends>
  <depends>com.redhat.devtools.lsp4ij</depends>
  <depends>org.jetbrains.plugins.textmate</depends>

  <extensions defaultExtensionNs="com.intellij">
    <applicationService serviceImplementation="com.github._1c_syntax.bsl.intellij.settings.LanguageServerSettingsState"/>
    <applicationConfigurable groupId="language" displayName="1C (BSL)" id="BSLConfigurable"
                             instance="com.github._1c_syntax.bsl.intellij.settings.BSLConfigurable"/>

    <!-- Иконки .bsl/.os без регистрации FileType, чтобы не перехватывать TextMate-подсветку -->
    <fileIconProvider implementation="com.github._1c_syntax.bsl.intellij.BslFileIconProvider"/>

    <!-- Встроенный TextMate-бандл с грамматикой BSL/SDBL -->
    <textmate.bundleProvider implementation="com.github._1c_syntax.bsl.intellij.textmate.BslTextMateBundleProvider"/>
  </extensions>

  <extensions defaultExtensionNs="com.redhat.devtools.lsp4ij">
    <server id="bsl-language-server"
            name="BSL Language Server"
            factoryClass="com.github._1c_syntax.bsl.intellij.lsp.BslLanguageServerFactory">
      <description><![CDATA[
        <a href="https://github.com/1c-syntax/bsl-language-server">BSL Language Server</a> —
        реализация Language Server Protocol для языка 1С:Предприятие (BSL) и OneScript.
        ]]></description>
    </server>
    <fileNamePatternMapping patterns="*.bsl;*.os"
                            serverId="bsl-language-server"
                            languageId="bsl"/>
  </extensions>

</idea-plugin>
